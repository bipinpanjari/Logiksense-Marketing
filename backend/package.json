{
  "name": "logik-sense-marketing-automation",
  "version": "1.0.0",
  "description": "Multi-tenant marketing automation platform with email, calling, and social media.",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nodemon --exec ts-node main.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:seed": "echo \"No seed script configured\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "qa-test": "node qa-test-runner.js",
    "qa-test:local": "API_URL=http://localhost:3000 node qa-test-runner.js",
    "worker:email": "node dist/workers/email-worker.js",
    "worker:scraper": "node dist/workers/scraper-worker.js",
    "worker:linkedin": "node dist/workers/linkedin-worker.js"
  },
  "keywords": [
    "marketing-automation",
    "email-sequencing",
    "crm",
    "calling",
    "social-media"
  ],
  "author": "Logik Sense",
  "license": "Proprietary",
