  inputTokens  Int?      @map("input_tokens")
  outputTokens Int?      @map("output_tokens")
  totalTokens  Int?      @map("total_tokens")
  costCents    Decimal?  @map("cost_cents") @db.Decimal(10, 4)
  byok         Boolean   @default(false)
  status       String    @default("ok") @db.VarChar(16)
  error        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId], map: "idx_ai_usage_workspace")
  @@index([createdAt(sort: Desc)], map: "idx_ai_usage_created")
  @@map("ai_usage_log")
}

model EnrichmentCache {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  provider    String    @db.VarChar(32)
  lookupKey   String    @map("lookup_key") @db.VarChar(255)
  result      Json      @default("{}")
  expiresAt   DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, lookupKey])
  @@index([workspaceId], map: "idx_enrichment_cache_workspace")
  @@map("enrichment_cache")
}

model ContactNote {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  leadId      String    @map("lead_id") @db.Uuid
  authorId    String?   @map("author_id") @db.Uuid
  body        String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)], map: "idx_contact_notes_lead")
  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_contact_notes_workspace")
  @@map("contact_notes")
}

model InboundReply {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  leadId         String?   @map("lead_id") @db.Uuid
  emailLogId     String?   @map("email_log_id") @db.Uuid
  campaignId     String?   @map("campaign_id") @db.Uuid
  enrollmentId   String?   @map("enrollment_id") @db.Uuid
  fromEmail      String    @map("from_email") @db.VarChar(255)
  toEmail        String?   @map("to_email") @db.VarChar(255)
  subject        String?   @db.VarChar(1024)
  snippet        String?
  inReplyTo      String?   @map("in_reply_to") @db.VarChar(512)
  messageId      String?   @map("message_id") @db.VarChar(512)
  rawHeaders     Json?     @map("raw_headers")
  receivedAt     DateTime  @default(now()) @map("received_at") @db.Timestamp(6)
