# === Database ===
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/logiksense_marketing"
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=logiksense
DB_PASSWORD=change-me
DB_NAME=logiksense_marketing

# === Auth / JWT ===
JWT_SECRET=change-me
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRATION=7d

# === Secrets / Vault ===
# 32+ byte secret, base64/hex/utf8 all accepted.
VAULT_ENCRYPTION_KEY=change-me-base64-256-bit
# Legacy alias (kept for the old SMTP crypto helper)
SMTP_ENCRYPTION_KEY=change-me-base64-256-bit

# === Server ===
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
# comma separated list; use * for dev only
CORS_ORIGINS=http://localhost:3001
FRONTEND_URL=http://localhost:3001
# Public API base (tracking links, webhooks, lead form URLs)
API_URL=http://localhost:3000

# === Rate limiting ===
RATE_LIMIT_DEFAULT=600

# === Onboarding (optional DNS / MX) ===
# If true, all users can complete onboarding without live MX/DKIM/SPF.
# ONBOARDING_SKIP_DNS_VALIDATION=false
# In production, the UI "skip DNS checks" checkbox is honored only if:
# ONBOARDING_ALLOW_CLIENT_DNS_SKIP=true
# (Omitted or development NODE_ENV: checkbox works without this.)

# === Queues (BullMQ + Redis) ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === Email defaults (per-workspace SMTP lives in email_configs, encrypted) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@logik-sense.com

# Bounce/complaint webhooks (SES SNS, etc.)
BOUNCE_WEBHOOK_SECRET=change-me

# === Feature flags ===
FEATURE_SCRAPER=false
FEATURE_LINKEDIN=false
FEATURE_AI_ICEBREAKER=false
FEATURE_ENRICHMENT=false

# === Kill switches (set to "true" to block automation globally) ===
SCRAPER_KILL_SWITCH=false
LINKEDIN_KILL_SWITCH=false

# === Workers (API process; set to "false" in worker-only deployments if needed) ===
EMAIL_WORKER_ENABLED=true
EMAIL_WORKER_CONCURRENCY=4
SEQUENCE_WORKER_CONCURRENCY=2
SCRAPER_WORKER_ENABLED=true
SCRAPER_WORKER_CONCURRENCY=1
SCRAPER_SCHEDULER_ENABLED=true
LINKEDIN_WORKER_ENABLED=true
LINKEDIN_WORKER_CONCURRENCY=1

# === Advanced: scraper (optional — omit for defaults; use when tuning performance or long jobs) ===
# SCRAPER_LOCK_DURATION_MS=900000
# Queue: default 1 attempt (browser runs are long; retries were re-running the same job in ~30s)
# SCRAPER_QUEUE_ATTEMPTS=1
# Bull “stalled” check interval (ms); long Playwright work needs a high value
# SCRAPER_STALLED_INTERVAL_MS=300000
# SCRAPER_RECOVER_RUNNING_ON_BOOT=true
# SCRAPER_WEBSITE_ENABLED=false
# SCRAPER_PLACE_CONCURRENCY=2
# SCRAPER_WEBSITE_MAX_PATHS=4
# SCRAPER_PAGE_TIMEOUT_MS=12000

# === Campaign tuning ===
CAMPAIGN_SEND_JITTER_MS=2000

# === Playwright (scraper + LinkedIn) ===
LINKEDIN_HEADLESS=true
# One-time from backend/: npx playwright install chromium  (otherwise browser launch hangs)
# PLAYWRIGHT_BROWSER_TIMEOUT_MS=120000
# Linux/Docker only if Chromium fails to spawn: SCRAPER_CHROMIUM_NO_SANDBOX=true
# English UI for Google Maps (default en-US). Override e.g. bn-BD only if you want local language.
# SCRAPER_BROWSER_LOCALE=en-US
# SCRAPER_ACCEPT_LANGUAGE=en-US,en;q=0.9
# BROWSER_DATA_DIR=./.browser-data

# === Third-party (BYOK lives per-workspace in vault_secrets; these are fallbacks) ===
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PRICING_JSON=
ZEROBOUNCE_API_KEY=
APOLLO_API_KEY=

# === Observability ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# GIT_SHA=
# RELEASE=

# === LLM (Ollama, optional) ===
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral
DOC_STORAGE_DIR=./documents
